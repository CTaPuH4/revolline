{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "title": "Requests per second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (route) (rate(revolline_http_requests_total{route=~\"api/.*\"}[5m]))", "legendFormat": "{{route}}"}]
    },
    {
      "title": "p95 latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, route) (rate(revolline_http_request_duration_seconds_bucket{route=~\"api/.*\"}[5m])))", "legendFormat": "{{route}}"}]
    },
    {
      "title": "HTTP responses",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (status) (rate(revolline_http_requests_total{route=~\"api/.*\"}[5m]))", "legendFormat": "HTTP {{status}}"}]
    },
    {
      "title": "5xx error rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []},
      "targets": [{"expr": "sum(rate(revolline_http_requests_total{route=~\"api/.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(revolline_http_requests_total{route=~\"api/.*\"}[5m])), 0.001)", "legendFormat": "5xx"}]
    },
    {
      "title": "Slowest endpoints (p95)",
      "type": "table",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 16},
      "targets": [{"expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(revolline_http_request_duration_seconds_bucket{route=~\"api/.*\"}[5m]))))", "format": "table", "instant": true}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["revolline", "api"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "ReVolline API Overview",
  "uid": "revolline-api",
  "version": 1
}
